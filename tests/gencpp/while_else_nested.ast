# RUN: %trans %s > %t.cpp
# RUN: %cxx -fsyntax-only -std=c++17 %t.cpp > %t.log 2>&1
# CHECK: int main() {
# CHECK: if (!(x > 0)) goto
# CHECK: else:;
# CHECK: Syntax check: OK
#
# AST description:
# Тест while с блоком else и вложенными конструкциями
FuncDecl name=main ret=int
  BlockStmt
    VarDecl name=x type=int
      IntLiteral value=10
    VarDecl name=counter type=int
      IntLiteral value=0
    # While с else блоком, внутри которого вложенный while
    WhileStmt label=main_loop
      BinaryOp op=>
        VarRef name=x
        IntLiteral value=0
      BlockStmt
        ExprStmt
          CallExpr name=print
            VarRef name=x
        # break внутри тела - должен перейти к end
        IfStmt
          BinaryOp op==
            VarRef name=x
            IntLiteral value=5
          ThenBlock
            BreakStmt label=main_loop
        # continue внутри тела - должен перейти к condition
        IfStmt
          BinaryOp op==
            VarRef name=x
            IntLiteral value=8
          ThenBlock
            ContinueStmt label=main_loop
        AssignmentStmt target=x
          BinaryOp op=-
            VarRef name=x
            IntLiteral value=1
      WhileElseBlock
        ExprStmt
          CallExpr name=print
            StringLiteral value="loop finished"
        # Вложенный while внутри else блока (без метки)
        WhileStmt
          BinaryOp op=<
            VarRef name=counter
            IntLiteral value=3
          BlockStmt
            ExprStmt
              CallExpr name=print
                StringLiteral value="cleanup"
            AssignmentStmt target=counter
              BinaryOp op=+
                VarRef name=counter
                IntLiteral value=1
    ReturnStmt
      IntLiteral value=0