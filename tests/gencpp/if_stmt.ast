# RUN: %trans %s > %t.cpp
# RUN: %cxx -fsyntax-only -std=c++17 %t.cpp > %t.log 2>&1
# CHECK: int main() {
# CHECK: int x = 10;
# CHECK: if (x > 0) {
# CHECK: print("positive");
# CHECK: } else {
# CHECK: print("non-positive");
# CHECK: }
# CHECK: return 0;
#
# AST description:
FuncDecl name=main ret=int
  BlockStmt
    VarDecl name=x type=int
      IntLiteral value=10
    IfStmt
      BinaryOp op=>
        VarRef name=x
        IntLiteral value=0
      ThenBlock
        ExprStmt
          CallExpr name=print
            StringLiteral value=positive
      ElseBlock
        ExprStmt
          CallExpr name=print
            StringLiteral value=non-positive
    ReturnStmt
      IntLiteral value=0