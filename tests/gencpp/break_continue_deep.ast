# RUN: %trans %s > %t.cpp
# RUN: %cxx -fsyntax-only %t.cpp > %t.log 2>&1
# CHECK: int main() {
# CHECK: Syntax check: OK
#
# AST description:
# Тест глубокой вложенности (3 уровня) с break/continue по меткам
FuncDecl name=main ret=Int
  BlockStmt
    VarDecl name=i type=Int
      IntLiteral value=0
    VarDecl name=j type=Int
      IntLiteral value=0
    VarDecl name=k type=Int
      IntLiteral value=0
    VarDecl name=result type=Int
      IntLiteral value=0
    # Уровень 1: while с меткой outer
    WhileStmt label=outer
      BinaryOp op=<
        VarRef name=i
        IntLiteral value=3
      BlockStmt
        AssignmentStmt target=j
          IntLiteral value=0
        # Уровень 2: do-while с меткой middle
        DoWhileStmt label=middle
          BlockStmt
            AssignmentStmt target=k
              IntLiteral value=0
            # Уровень 3: while с меткой inner
            WhileStmt label=inner
              BinaryOp op=<
                VarRef name=k
                IntLiteral value=5
              BlockStmt
                # break без метки - выход из inner
                IfStmt
                  BinaryOp op==
                    VarRef name=k
                    IntLiteral value=1
                  ThenBlock
                    BreakStmt
                # continue с меткой inner - к условию inner
                IfStmt
                  BinaryOp op==
                    VarRef name=k
                    IntLiteral value=2
                  ThenBlock
                    ContinueStmt label=inner
                # break с меткой middle - выход из do-while
                IfStmt
                  BinaryOp op==
                    VarRef name=k
                    IntLiteral value=3
                  ThenBlock
                    BreakStmt label=middle
                # continue с меткой outer - к условию внешнего
                IfStmt
                  BinaryOp op==
                    VarRef name=k
                    IntLiteral value=4
                  ThenBlock
                    ContinueStmt label=outer
                AssignmentStmt target=k
                  BinaryOp op=+
                    VarRef name=k
                    IntLiteral value=1
            AssignmentStmt target=j
              BinaryOp op=+
                VarRef name=j
                IntLiteral value=1
          BinaryOp op=<
            VarRef name=j
            IntLiteral value=3
        AssignmentStmt target=i
          BinaryOp op=+
            VarRef name=i
            IntLiteral value=1
    ReturnStmt
      IntLiteral value=0