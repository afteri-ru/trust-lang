// Test object file generation (-c) without binding header
// RUN: %trust %s -c -o %t_object.o 2>&1
// RUN: test -f %t_object.o

// Test shared library generation (-l) with default binding header
// RUN: %trust %s -l -o %t_shared.so 2>&1
// RUN: test -f %t_shared.so
// RUN: test -f %t.h
// RUN: %FileCheck %s --check-prefix=HEADER --input-file %t.h

// Test static library generation (-a) with specific binding header
// RUN: %trust %s -a -o %t_static.a --binding-header=%t_static.h 2>&1
// RUN: test -f %t_static.a
// RUN: test -f %t_static.h
// RUN: %FileCheck %s --check-prefix=HEADER_STATIC --input-file %t_static.h

{%
int hello_trust_lib() {
    return 42;
}
%}

// HEADER-NOT: __
// HEADER: int hello_trust_lib()
// HEADER_STATIC: int hello_trust_lib()
